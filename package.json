{
  "name": "gbt-register-manager",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:download-wix-nsis": "powershell -ExecutionPolicy Bypass -File scripts/download_tauri_wix_nsis_tools.ps1",
    "tauri:prepare-tools": "powershell -ExecutionPolicy Bypass -File scripts/prepare_tauri_tools.ps1",
    "tauri:build": "npm run tauri:prepare-tools && tauri build",
    "sidecar:build": "powershell -ExecutionPolicy Bypass -File python-sidecar/build_sidecar.ps1"
  },
  "dependencies": {
    "katex": "^0.16.45",
    "naive-ui": "^2.40.3",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/cli": "2.10.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
